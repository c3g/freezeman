# EditorConfig is awesome: https://editorconfig.org

# top-most EditorConfig file
root = true

# General settings
[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true

# 4 space indentation
[*.{js,ts,jsx,tsx,html,css,scss,json,py}]
indent_style = space
indent_size = 4
